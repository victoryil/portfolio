---
import { PROFILE } from '../data/portfolio';
import Terminal from './Terminal.astro';
---
<section style="margin-top:28px">
  <style>
    @keyframes pulse {
      0%   { box-shadow: 0 0 0 0 var(--accent); }
      70%  { box-shadow: 0 0 0 8px transparent; }
      100% { box-shadow: 0 0 0 0 transparent; }
    }
    .hero-grid { display:grid; grid-template-columns:1.05fr 1fr; gap:24px; margin-top:36px; align-items:stretch; }
    @media (max-width:880px) { .hero-grid { grid-template-columns:1fr; } }
    .hero-left { display:flex; flex-direction:column; gap:18px; }
    .status-badge {
      display:inline-flex; align-items:center; gap:8px;
      font-size:12px; color:var(--muted); font-family:var(--mono);
      padding:6px 10px;
      border:1px solid var(--border); border-radius:999px;
      background:var(--panel-2); width:fit-content;
    }
    .status-pulse {
      width:8px; height:8px; border-radius:50%;
      background:var(--accent); animation:pulse 2s infinite;
    }
    .hero-name {
      font-family:var(--mono);
      font-size:clamp(38px,6vw,64px);
      font-weight:600; line-height:1.02;
      letter-spacing:-0.025em; margin:0;
    }
    .hero-role {
      font-family:var(--mono);
      font-size:clamp(15px,1.6vw,18px);
      color:var(--text-2); line-height:1.5; max-width:560px;
    }
    .hero-meta { display:flex; flex-wrap:wrap; gap:8px; }
    .hero-ctas { display:flex; flex-wrap:wrap; gap:10px; margin-top:4px; }
    .btn {
      font-family:var(--mono); font-size:13px;
      padding:10px 14px; border-radius:8px;
      border:1px solid var(--border); background:var(--panel-2);
      color:var(--text); cursor:pointer; text-decoration:none;
      display:inline-flex; align-items:center; gap:8px;
    }
    .btn:hover { text-decoration:none; border-color:var(--border-strong); background:var(--panel); }
    .btn-primary {
      background:var(--accent); color:#0a0e0f;
      border-color:var(--accent); font-weight:600;
    }
    .btn-primary:hover { opacity:.9; }
    .ascii-card {
      padding:14px; font-family:var(--mono); font-size:12px;
      color:var(--text-2); line-height:1.7;
    }
    .kv { display:grid; grid-template-columns:120px 1fr; gap:4px; }
    .kv-k { color:var(--muted); }
    .kv-v { color:var(--text); }
  </style>

  <div class="hero-grid">
    <!-- Left: identity -->
    <div class="hero-left">
      <div class="status-badge">
        <span class="status-pulse"></span>
        available for tech talks · open-source collabs
      </div>

      <h1 class="hero-name">
        <span class="muted">$</span> {PROFILE.handle}<span class="cursor"></span>
      </h1>

      <div style="font-family:var(--mono);font-size:14px;color:var(--muted)">
        <span class="accent">// </span>
        {PROFILE.role} <span class="accent2">@ {PROFILE.company}</span>
      </div>

      <p class="hero-role">{PROFILE.tagline}</p>

      <div class="hero-meta">
        <span class="chip green">● online</span>
        <span class="chip">📍 {PROFILE.location}</span>
        <span class="chip blue">team_lead = true</span>
        <span class="chip warn">spark · spring · k8s</span>
      </div>

      <div class="hero-ctas">
        <a href={`mailto:${PROFILE.email}`} class="btn btn-primary">
          <span>✉</span> {PROFILE.email}
        </a>
        <a href={PROFILE.github} target="_blank" rel="noreferrer" class="btn">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.55v-2.1c-3.2.7-3.87-1.36-3.87-1.36-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.75 1.18 1.75 1.18 1.02 1.75 2.68 1.24 3.34.95.1-.74.4-1.24.72-1.53-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.18 1.18.92-.26 1.91-.39 2.9-.39.99 0 1.98.13 2.9.39 2.21-1.49 3.18-1.18 3.18-1.18.62 1.59.23 2.76.11 3.05.74.81 1.18 1.84 1.18 3.1 0 4.43-2.69 5.41-5.26 5.69.41.36.78 1.06.78 2.13v3.16c0 .31.21.67.8.55C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z"/>
          </svg>
          github
        </a>
        <a href={PROFILE.linkedin} target="_blank" rel="noreferrer" class="btn">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M4.98 3.5C4.98 4.88 3.87 6 2.5 6S.02 4.88.02 3.5 1.13 1 2.5 1s2.48 1.12 2.48 2.5zM.22 8h4.56v14H.22V8zm7.74 0h4.37v1.92h.06c.61-1.15 2.1-2.36 4.32-2.36 4.62 0 5.47 3.04 5.47 6.99V22h-4.56v-6.21c0-1.48-.03-3.39-2.07-3.39-2.07 0-2.39 1.62-2.39 3.29V22H7.96V8z"/>
          </svg>
          linkedin
        </a>
        <a href="#projects" class="btn" id="see-projects-btn">
          <span class="accent">→</span> see projects
        </a>
      </div>
    </div>

    <!-- Right: terminal + ascii card -->
    <div style="display:flex;flex-direction:column;gap:16px">
      <Terminal />
      <div class="panel ascii-card">
        <div class="kv">
          <span class="kv-k">$ uname -r</span>
          <span class="kv-v">team-lead/v7.0</span>
          <span class="kv-k">$ uptime</span>
          <span class="kv-v">7y, load avg: spark, spring, k8s</span>
          <span class="kv-k">$ now playing</span>
          <span class="kv-v">building data frameworks @ santander</span>
          <span class="kv-k">$ side quest</span>
          <span class="kv-v">🦀 Rust mod · 📅 react calendar lib</span>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.getElementById('see-projects-btn')?.addEventListener('click', e => {
    e.preventDefault();
    const el = document.getElementById('projects');
    if (el) window.scrollTo({ top: el.getBoundingClientRect().top + window.scrollY - 24, behavior: 'smooth' });
  });
</script>
